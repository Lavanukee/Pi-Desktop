{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["biome.json", "pnpm-workspace.yaml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "build:swift": {
      "cache": false,
      "outputs": ["swift/.build/release/**"]
    }
  }
}
