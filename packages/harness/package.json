{
  "name": "@pi-desktop/harness",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "pi extension: task classifier, toolset presets, tool search, repair rungs 3-5, permission modes, effort mapping, small-model warnings, and the /harness command protocol.",
  "keywords": [
    "pi-package"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./corp": "./src/corp/index.ts",
    "./permissions": "./src/permissions/rules.ts"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "0.68.1",
    "@mariozechner/pi-coding-agent": "0.68.1",
    "@pi-desktop/browser-use": "workspace:*",
    "@pi-desktop/mac-connectors": "workspace:*",
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@pi-desktop/provider-llamacpp": "workspace:*",
    "@pi-desktop/shared": "workspace:*",
    "@types/node": "^24.13.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
